          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Receiver -> DynamoDB (green) -->
        <mxCell id="e_receiver_ddb" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#009900;strokeWidth=2;flowAnimation=1;" edge="1" parent="region" source="receiver" target="ddb">
